# Server
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/brandora?retryWrites=true&w=majority

# JWT
JWT_SECRET=brandora_super_secret_jwt_key_minimum_32_chars_2024
JWT_REFRESH_SECRET=brandora_refresh_secret_key_minimum_32_chars_2024
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# OpenAI (Primary AI)
OPENAI_API_KEY=sk-proj-your_openai_key_here

# Google Gemini (Secondary AI)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude (Fallback AI)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# HuggingFace (Free fallback)
HUGGINGFACE_API_KEY=hf_your_huggingface_key_here

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# App
APP_NAME=Brandora
SUPPORT_EMAIL=info@brandora.com
FRONTEND_URL=http://localhost:3000
